{
  "permissions": {
    "deny": [
      "Read(/root/.claude/**)",
      "Read(/root/.claude)",
      "Read(//root/.claude/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "/usr/local/bin/dabs-guard-claude-vault" }
        ]
      }
    ]
  }
}
